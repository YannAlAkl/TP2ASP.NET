@model IEnumerable<Yann_Al_Akl_WS1_TP2_Développement_Web_Serveur__1.Models.ViewModels.UserStatsViewModel>

@{
    ViewData["Title"] = "Liste des statistiques des utilisateurs";
}

<h1>Statistiques des utilisateurs</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Nouvel utilisateur</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Nom d'utilisateur</th>
            <th>Courriel</th>
            <th>Nombre de sujets créés</th>
            <th>Nombre de messages créés</th>
            <th>Dernière activité</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.UserName</td>
                <td>@user.Email</td>
                <td>@user.SubjectCount</td>
                <td>@user.MessageCount</td>
                <td>
                    @if (user.LastActivity == DateTime.MinValue)
                    {
                        <span class="text-muted">Jamais</span>
                    }
                    else
                    {
                        @user.LastActivity.ToString("dd/MM/yyyy HH:mm")
                    }
                </td>
            </tr>
        }
    </tbody>
</table>