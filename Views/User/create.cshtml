@model IEnumerable<Yann_Al_Akl_WS1_TP2_Développement_Web_Serveur__1.Models.ViewModels.UserCredentials>
@{
    ViewData["Title"] = "Create";
}
<p>
    <a asp-action="Create">Create New</a>
</p>
@foreach (var user in Model)
{
    <form action="/" method="post">
        <h3>Nouvel utilisateur</h3>

        <div>
            <label for="username">Nom d'utilisateur :@user.UserName</label>
            <input type="text" id="username" name="username" required>
        </div>

        <div>
            <label for="email">Email :@user.Email</label>
            <input type="email" id="email" name="email" required>
        </div>

        <div>
            <label for="password">Mot de passe :@user.Password</label>
            <input type="password" id="password" name="password" required>
        </div>

        <div>
            <label for="status">Statut : @user.Status</label>
            <select id="status" name="status">
                <option value="user" selected="@(user.Status == "user")">Utilisateur standard</option>
                <option value="admin" selected="@(user.Status == "admin")">Admin</option>
            </select>
        </div>



        <button type="submit">Créer le compte</button>
    </form>
    }
