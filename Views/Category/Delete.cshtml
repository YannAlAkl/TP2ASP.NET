@model Yann_Al_Akl_WS1_TP2_Développement_Web_Serveur__1.Models.Category

@{
    ViewData["Title"] = "Supprimer la catégorie";
}

<h1 class="text-danger">Supprimer la catégorie</h1>

<h3>Êtes-vous sûr de vouloir supprimer cette catégorie ?</h3>
<p class="text-muted"><em>Tous les sujets et messages liés seront également désactivés.</em></p>
<hr />

<dl class="row">
    <dt class="col-sm-2">Nom</dt>
    <dd class="col-sm-10">@Model.Name</dd>

    <dt class="col-sm-2">Description</dt>
    <dd class="col-sm-10">@Html.Raw(Model.Description)</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Supprimer" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary">Annuler</a>
</form>