@model Yann_Al_Akl_WS1_TP2_Développement_Web_Serveur__1.Models.Category
@{
    ViewData["Title"] = "Details";
}
<h1>@Html.DisplayFor(model => model.Name)</h1>
<div class="forum-container">
    <p>
        <a asp-controller="Subject" asp-action="Create" class="btn btn-primary">Ajouter</a>
    </p>

    <table class="table forum-table">
        <thead>
            <tr class="forum-header">
                <th>SUJET</th>
                <th class="text-center">MESSAGES</th>
                <th class="text-center">VUES</th>
                <th class="text-center">Action</th>
                <th>DERNIÈRE RÉPONSE</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Subjects != null && Model.Subjects.Any())
            {
                @foreach (var subject in Model.Subjects)
                {
                    var lastUserMessage = subject.Messages.Where(m => !m.IsDeleted).OrderByDescending(m => m.CreatedAt).FirstOrDefault();
                    <tr>
                        <td>
                            <div class="subject-title">
                                <a asp-controller="Subject" asp-action="Details" asp-route-id="@subject.Id">
                                    <strong>@subject.Title</strong>
                                </a>
                                @if (subject.CreatedAt > DateTime.Now.AddDays(-2))
                                {
                                    <span class="badge bg-success">Nouveau</span>
                                }
                            </div>
                            <small class="text-muted">
                                par @(subject.User?.UserName ?? "Anonyme") - @subject.CreatedAt.ToString("d MMM yyyy")
                            </small>
                        </td>
                        <td class="text-center align-middle">@subject.Messages.Count()</td>
                        <td class="text-center align-middle">@subject.ViewCount</td>
                        <td class="text-center align-middle">
                            <a asp-controller="Subject" asp-action="Delete" asp-route-id="@subject.Id"
                               class="btn btn-sm btn-danger me-1"
                               onclick="return confirm('Voulez-vous vraiment supprimer ce sujet ?');">
                                <i class="bi bi-trash"></i>
                            </a>
                            <a asp-controller="Subject" asp-action="Edit" asp-route-id="@subject.Id"
                               class="btn btn-sm btn-warning">
                                <i class="bi bi-pencil-square"></i>
                            </a>
                        </td>
                        <td class="align-middle">
                            <div><strong>@lastUserMessage?.User?.UserName</strong></div>
                            <small class="text-muted">il y a 12 min</small>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="text-center">Aucun sujet disponible pour cette catégorie.</td>
                </tr>
            }
        </tbody>
    </table>
</div>