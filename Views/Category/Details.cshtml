@model Yann_Al_Akl_WS1_TP2_Développement_Web_Serveur__1.Models.Category
@{
    ViewData["Title"] = "Details";
}

<div class="container mt-4">
    <h1 class="mb-4">@Model.Name</h1>

    <div class="forum-container">
        <p>
            @if (User.Identity.IsAuthenticated)
            {
                <a asp-controller="Subject" asp-action="Create" class="btn btn-primary shadow-sm">
                    <i class="bi bi-plus-circle"></i> Ajouter un sujet
                </a>
            }
            else
            {
                
                    <i class="bi bi-box-arrow-in-right"></i> Se connecter pour ajouter
                </a>
            }
        </p>

        <table class="table forum-table align-middle">
            <thead class="table-dark">
                <tr class="forum-header">
                    <th style="width: 45%">SUJET</th>
                    <th class="text-center">MESSAGES</th>
                    <th class="text-center">VUES</th>
                    <th class="text-center">ACTIONS</th>
                    <th style="width: 20%">DERNIÈRE RÉPONSE</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var subject in Model.Subjects ?? Enumerable.Empty<Subject>())
                {
                    var lastMsg = subject.Messages?.OrderByDescending(m => m.CreatedAt).FirstOrDefault();
                    <tr>
                        <td>
                            <div class="subject-title">
                                <a asp-controller="Subject" asp-action="Details" asp-route-id="@subject.Id" class="text-decoration-none fw-bold">
                                    @subject.Title
                                </a>
                                @if (subject.CreatedAt > DateTime.Now.AddDays(-2))
                                {
                                    <span class="badge bg-success ms-1">Nouveau</span>
                                }
                            </div>
                            <small class="text-muted">
                                par @(subject.User?.UserName ?? "Anonyme") • @subject.CreatedAt.ToString("d MMM yyyy")
                            </small>
                        </td>
                        <td class="text-center">@subject.Messages?.Count()</td>
                        <td class="text-center">@subject.ViewCount</td>
                        <td class="text-center">
                            @if (User.Identity.IsAuthenticated)
                            {
                                <div class="btn-group">
                                    <a asp-controller="Subject" asp-action="Edit" asp-route-id="@subject.Id" class="btn btn-sm btn-outline-warning">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a asp-controller="Subject" asp-action="Delete" asp-route-id="@subject.Id" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            }
                            else
                            {
                                <div class="btn-group">
                                    
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            }
                        </td>
                        <td>
                            @if (lastMsg != null)
                            {
                                <div class="fw-bold text-truncate" style="max-width: 150px;">@lastMsg.User?.UserName</div>
                                <small class="text-muted">@GetRelativeTime(lastMsg.CreatedAt)</small>
                            }
                            else
                            {
                                <span class="text-muted small">Aucune réponse</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@functions {
    string GetRelativeTime(DateTime d)
    {
        var ts = DateTime.Now - d;
        if (ts.TotalDays >= 1) return $"il y a {(int)ts.TotalDays} j";
        if (ts.TotalHours >= 1) return $"il y a {(int)ts.TotalHours} h";
        return $"il y a {(int)ts.TotalMinutes} min";
    }
}
