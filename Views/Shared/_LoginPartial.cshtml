@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<ul class="navbar-nav align-items-center gap-2">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item">
            <a class="nav-link nav-pill" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
                👤 @User.Identity?.Name
            </a>
        </li>
        <li class="nav-item">
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout"
                  asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button type="submit" class="btn btn-outline-light btn-sm rounded-pill px-3">Déconnexion</button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link nav-pill" asp-area="Identity" asp-page="/Account/Login">Connexion</a>
        </li>
        <li class="nav-item">
            <a class="btn btn-accent rounded-pill px-4" asp-area="Identity" asp-page="/Account/Register">S'inscrire</a>
        </li>
    }
</ul>