<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ForumSport</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body class="theme-arena">
    <header class="site-header">
        <nav class="navbar navbar-dark navbar-expand-sm">
            <div class="container-fluid px-4">

                <!-- Logo + Nom -->
                <a class="navbar-brand d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                    <div class="brand-logo-wrapper">
                        <img src="~/images/Sports.webp" alt="ForumSportQC " class="brand-logo" />
                    </div>
                    <span class="brand-text">Forum<span class="brand-accent">Sport</span></span>
                </a>
                <!-- Toggler mobile -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Liens + Auth -->
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link nav-pill" asp-area="" asp-controller="Home" asp-action="Index">Accueil</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-pill" asp-area="" asp-controller="Home" asp-action="Privacy">Confidentialité</a>
                        </li>
                        @if(User.IsInRole("Admin")){
                        <li class="nav-item">
                            <a class="nav-link nav-pill" asp-area="" asp-controller="User" asp-action="Index">Utilisateurs</a>
                            </li>
                        }
                        <!--Je ne vois pas ceci-->
                        @if (User.IsInRole("Admin")){
                        <li class="nav-item">
                            <a class="nav-link nav-pill" asp-area="" asp-controller="User" asp-action="Create">Nouvelle Utilisateur</a>
                        </li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>

            </div>
        </nav>
        <div class="header-accent-bar"></div>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="site-footer">
        <div class="container">
            &copy; 2026 - ForumSport &mdash;
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Confidentialité</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>