@model Yann_Al_Akl_WS1_TP2_Développement_Web_Serveur__1.Models.Message

@{
    ViewData["Title"] = "Modifier le message";
}

<h1>Modifier le message</h1>

<h4>Message</h4>
<hr />

<div class="row">
    <div class="col-md-8">
        @* Info contextuelle *@
        <div class="alert alert-light border mb-3">
            <small class="text-muted">
                Posté par <strong>@(Model.User?.UserName ?? "Inconnu")</strong>
                le @Model.CreatedAt.ToString("dd MMM. yyyy 'à' HH'h'mm")
            </small>
        </div>

        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="SubjectId" />

            <div class="form-group mb-3">
                <label asp-for="Content" class="control-label">Contenu</label>
                <textarea asp-for="Content" id="messageEditContent" class="form-control" rows="6"></textarea>
                <span asp-validation-for="Content" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Sauvegarder" class="btn btn-primary" />
                <a asp-action="Details" asp-controller="Subject" asp-route-id="@Model.SubjectId"
                   class="btn btn-secondary">Annuler</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }

    <script src="https://cdn.tiny.cloud/1/2y3kz8ef292tu9hgci5w1gr7uqhonmx9li56zhgumnksp5hj/tinymce/8/tinymce.min.js"
            referrerpolicy="origin"></script>
    <script>
        tinymce.init({
            selector: '#messageEditContent',
            height: 250,
            menubar: false,
            plugins: 'lists link',
            toolbar: 'undo redo | bold italic underline | bullist numlist | link | removeformat'
        });
    </script>
}