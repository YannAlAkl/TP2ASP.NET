@model IEnumerable<Yann_Al_Akl_WS1_TP2_Développement_Web_Serveur__1.Models.Subject>

@{
    ViewData["Title"] = "Liste des sujets";
}

<h1>Liste des sujets</h1>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Titre</th>
            <th>Catégorie</th>
            <th class="text-center">Vues</th>
            <th>Créé le</th>
            <th>Auteur</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@(item.Category?.Name ?? "—")</td>
                <td class="text-center">@item.ViewCount</td>
                <td>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                <td>@(item.User?.UserName ?? "Anonyme")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Détails</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Modifier</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Supprimer</a>
                </td>
            </tr>
        }
    </tbody>
</table>